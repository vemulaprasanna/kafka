Procedure
Step-1:
SSH into Mongodb VM in production Environment as a root user.
Step-2:
Change the directory to /opt
	cd /opt
Create a folder as deletion to store respective script files and folders.
	mkdir deletion
Create a folder for call purge for each organization
	mkdir OrgWiseDeletion
Step-3:
Create .js files in respective folder to store scripts
In OrgWiseDeletion folder
Create script files
vi mongoscript.sh 
		#bash
PATH=/var/lib/mongodb-mms-automation/bin:$PATH
mongo mongodb-dev.tenfold.com:27017/callinize query.js


vi query.js
db.auth('Need username','Need password');

let selected = ['63eb93f2237f3754fe072731']

print('########################################################');
print('Starting Deletion At, ' + Date());
for (let i = 0; i < selected.length; i++) {
	var counter=0;
	var remainingrecords = 0;
	var totalrecords = db.calls.find({ "_organization" : ObjectId(selected[i]), createdDate: { $gt : new Date('2023-03-04'), $lt : new Date('2023-03-04')}}).count();
	print('──────────────────────────────────────────────────────────────────────────────');
	print(selected[i] + ' Total Records : '+ totalrecords);
	db.calls.find({ "_organization" : ObjectId(selected[i]), createdDate: { $gt : new Date('2023-03-04'), $lt : new Date('2023-03-04')} }).forEach( function(x){
     		db.calls.remove({_id : x._id});
     		counter = counter+1;
     		if(counter==1000000){
          		remainingrecords = db.calls.find({ "_organization" : ObjectId(selected[i])}).count();
          		print((100 - (remainingrecords/totalrecords)*100) + ' % Deleted, At ' + Date());counter = 0;
     		}
	});
	print('──────────────────────────────────────────────────────────────────────────────');
}
print('Completed Deletion At, ' + Date());
print('########################################################');
Now change the mongoscript.sh to executable file
chmod +x mongoscript.sh
Run the purging bash script
			nohup ./mongoscript.sh &
To check the output.
Go into the cd  /opt/deletion/OrgWiseDeletion
Now give command: ls -la
You can absorb nohup.out file
Cmd: tail -100f nohup.out
